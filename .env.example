# ═══════════════════════════════════════════════════
# Member Plus — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════

# === Salla Partner Portal (REQUIRED) ===
# Get these from https://salla.partners → Your App → Settings
SALLA_API_KEY=
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_WEBHOOK_SECRET=

# === Database ===
DB_PASSWORD=your-strong-password-here

# === Security (REQUIRED — generate unique values) ===
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
ENCRYPTION_KEY=

# === Email (optional — mock if empty) ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=Member Plus <no-reply@memberplus.sa>

# === Environment ===
ENVIRONMENT=production
